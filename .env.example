# AcadVex 环境变量配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# ── LLM API ──────────────────────────────────────────────────────────────────
# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ── Langfuse 可观测性（可选）─────────────────────────────────────────────────
# 本地部署时使用 host.docker.internal（Docker 内访问宿主机），
# 或填写 Langfuse Cloud 地址（https://cloud.langfuse.com）
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_BASE_URL=http://host.docker.internal:3000

# ── 应用设置 ─────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 使用的数据集：dblp 或 acm
DATASET=dblp

# ── HuggingFace 离线模式 ──────────────────────────────────────────────────────
# 生产/Docker 环境建议开启，避免启动时访问 huggingface.co
# 前提：已预先下载模型缓存（bge-small-zh-v1.5, ms-marco-MiniLM-L-6-v2）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
